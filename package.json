{
  "name": "wonderful-fetch",
  "version": "2.0.2",
  "description": "A wrapper around fetch.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "npm run prepare:watch",
    "build": "node -e \"require('prepare-package')()\"",
    "prepare": "node -e \"require('prepare-package')()\"",
    "test": "npm run build && mocha test/ --recursive --timeout=30000",
    "prepare:watch": "node -e \"require('prepare-package/watch')()\""
  },
  "preparePackage": {
    "input": "src",
    "output": "dist",
    "type": "bundle",
    "build": {
      "formats": [
        "esm",
        "cjs",
        "iife"
      ],
      "iife": {
        "globalName": "WonderfulFetch",
        "fileName": "wonderful-fetch.min.js"
      },
      "external": [
        "fs-jetpack",
        "mime-types",
        "stream",
        "path"
      ]
    },
    "replace": {}
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itw-creative-works/wonderful-fetch"
  },
  "keywords": [
    "rest api"
  ],
  "author": "ITW Creative Works",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/itw-creative-works/wonderful-fetch/issues"
  },
  "homepage": "https://itwcreativeworks.com",
  "browser": {
    "fs-jetpack": false,
    "mime-types": false
  },
  "dependencies": {
    "fs-jetpack": "^5.1.0",
    "itwcw-package-analytics": "^1.0.8",
    "mime-types": "^3.0.2"
  },
  "devDependencies": {
    "mocha": "^11.7.5",
    "prepare-package": "^2.0.5"
  }
}
